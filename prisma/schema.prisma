generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  role        Role         @default(MEMBER)
  createdAt   DateTime     @default(now())
  rsvps       RSVP[]
  attendances Attendance[]
}

model Society {
  id          Int    @id @default(autoincrement())
  name        String
  description String
}

model Event {
  id          Int          @id @default(autoincrement())
  title       String
  location    String
  date        DateTime
  description String
  rsvps       RSVP[]
  attendances Attendance[]
}

model RSVP {
  userId  Int
  eventId Int
  user    User  @relation(fields: [userId], references: [id])
  event   Event @relation(fields: [eventId], references: [id])

  @@id([userId, eventId])
}

model Attendance {
  id         Int      @id @default(autoincrement())
  userId     Int
  eventId    Int
  attendedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  event      Event    @relation(fields: [eventId], references: [id])
}

enum Role {
  MEMBER
  ADMIN
  COMMITTEE
}
